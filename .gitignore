# Environments & secrets
.venv/
venv/
.env
*.pem

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Logs
logs/*
!logs/.gitkeep

# Data outputs (large / regenerable — never commit)
# No trailing slash: `data` at the repo root is a symlink to /mnt/data/...,
# and a trailing-slash pattern only matches real directories, not symlinks —
# verified via `git add -A --dry-run` staging the symlink under the old
# `data/` pattern. This form matches the entry regardless of type.
data

# Model checkpoints (hundreds of MB; live on the GPU box / local disk only)
checkpoints/

# Third-party clones (commit hash recorded in envs/ + SETUP.md instead)
third_party/
